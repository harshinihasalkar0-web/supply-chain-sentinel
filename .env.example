# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=supply_chain_sentinel
DB_USER=postgres
DB_PASSWORD=harshini123

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── OpenWeatherMap (optional – falls back to mock) ───
OPENWEATHER_API_KEY=

# ── Email Alerts ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ALERT_FROM=alerts@supply-sentinel.local

# ── Risk thresholds (scores 0-100) ───────────────────
RISK_HIGH_THRESHOLD=65
RISK_MEDIUM_THRESHOLD=40

# ── Scheduled re-analysis (cron, default every hour) ─
CRON_SCHEDULE=0 * * * *
